# M365 adapter environment variables (Teams / Copilot Chat)
# Copy to .env and fill your values before running: uv run langgraph-fabric-m365

# Foundry / Azure OpenAI settings
AZURE_OPENAI_ENDPOINT=https://your-foundry.services.ai.azure.com/api/projects/your-project
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-5.4
AZURE_OPENAI_API_VERSION=2025-11-15-preview

# MCP server settings (JSON list)
# For M365, set oauth_connection_name per server.
MCP_SERVERS=[{"name":"fabric","description":"Fabric analytics MCP server","url":"https://api.fabric.microsoft.com/v1/mcp/workspaces/<workspace-id>/dataagents/<agent-id>/agent","scope":"https://api.fabric.microsoft.com/.default","oauth_connection_name":"FabricOAuth2","timeout_seconds":120,"poll_interval_seconds":2}]

# Bot Service / Teams / Copilot Chat settings
MICROSOFT_APP_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_APP_PASSWORD=replace-with-bot-secret
MICROSOFT_TENANT_ID=00000000-0000-0000-0000-000000000000

# Service connection settings used by M365 Agents SDK
CONNECTIONS__SERVICE_CONNECTION__ID=service_connection
CONNECTIONS__SERVICE_CONNECTION__NAME=Default Service Connection
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=00000000-0000-0000-0000-000000000000
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=00000000-0000-0000-0000-000000000000
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__AUTHTYPE=ClientSecret
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=replace-with-bot-secret

# Runtime settings
LOG_LEVEL=INFO
# Per-logger overrides: LOG_LEVEL_OVERRIDE=langgraph_fabric_core.graph:DEBUG,azure.core:WARNING
LOG_LEVEL_OVERRIDE=
PORT=8000
