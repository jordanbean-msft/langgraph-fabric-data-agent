# API server environment variables
# Copy to .env and fill your values before running: uv run langgraph-fabric-api

# Foundry / Azure OpenAI settings
AZURE_OPENAI_ENDPOINT=https://your-foundry.services.ai.azure.com/api/projects/your-project
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-5.4
AZURE_OPENAI_API_VERSION=2025-11-15-preview

# Fabric Data Agent MCP settings
FABRIC_DATA_AGENT_MCP_URL=https://api.fabric.microsoft.com/v1/mcp/workspaces/<workspace-id>/dataagents/<agent-id>/agent
FABRIC_DATA_AGENT_SCOPE=https://api.fabric.microsoft.com/.default
FABRIC_DATA_AGENT_TIMEOUT_SECONDS=120
FABRIC_DATA_AGENT_POLL_INTERVAL_SECONDS=2

# Entra app registration for On-Behalf-Of (OBO) token exchange
# The API server exchanges the caller's JWT for a Fabric-scoped token using these credentials
MICROSOFT_APP_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_APP_PASSWORD=replace-with-client-secret
MICROSOFT_TENANT_ID=00000000-0000-0000-0000-000000000000

# Runtime settings
LOG_LEVEL=INFO
# Per-logger overrides: LOG_LEVEL_OVERRIDE=langgraph_fabric_core.graph:DEBUG,azure.core:WARNING
LOG_LEVEL_OVERRIDE=
PORT=8000
