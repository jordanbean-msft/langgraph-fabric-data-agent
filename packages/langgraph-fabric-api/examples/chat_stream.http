###############################################################################
# Chat Stream API Example: OAuth 2.0 Authorization Code Flow with PKCE
###############################################################################
# This example shows the Authorization Code Flow with PKCE (Proof Key for
# Public Client Exchange), which is the recommended flow for public clients
# (apps without a client secret) like this REST Client example.
#
# Flow:
# 1. Generate PKCE parameters (code_verifier and code_challenge)
# 2. Request authorization code from Entra ID (browser opens for sign-in)
# 3. Exchange authorization code + code_verifier for access token
# 4. Call the API with the token
#
# Prerequisites:
# - API_CLIENT_ID: Your API server app registration Client ID (resource/audience)
# - CALLER_CLIENT_ID: Your calling app registration Client ID (public client)
# - TENANT_ID: Your Azure tenant ID (or "common")
# - API_BASE_URL: The API server URL (localhost:8000 for local development)
# - redirectUri: Must be added to the calling app registration under Mobile and desktop applications
###############################################################################

### Configuration
@apiClientId = <your-api-app-client-id>
@callerClientId = <your-caller-public-client-id>
@tenantId = common
@apiBaseUrl = http://localhost:8000
@entraAuthority = https://login.microsoftonline.com
@redirectUri = http://localhost:3000/callback
@apiScope = api://{{apiClientId}}/access_as_user

### PKCE Parameters (generate new values for each flow)
# code_verifier: Random URL-safe string (43-128 chars)
# For production, generate: import secrets; secrets.token_urlsafe(64)
# For testing, use: ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_
@codeVerifier = ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789

# code_challenge: SHA256(code_verifier) base64url encoded
# For the test verifier above, the code_challenge is:
@codeChallenge = 20v8vU2gzYWmDDw30_vYgFx38V_Gsf3-YU7gp8j9tMA

###############################################################################
# REQUEST 1: Authorization code request
# Opens browser for user sign-in, returns authorization code
###############################################################################

# REST Client cannot perform interactive browser sign-in.
#
# STEP 1: Copy the URL template below, substitute configured values,
# and paste into your browser:
#
#   {{entraAuthority}}/{{tenantId}}/oauth2/v2.0/authorize
#     ?client_id={{callerClientId}}
#     &response_type=code
#     &scope={{apiScope}}
#     &redirect_uri={{redirectUri}}
#     &code_challenge={{codeChallenge}}
#     &code_challenge_method=S256
#     &prompt=select_account
#
#   URL-encode the scope value if needed (for example api%3A%2F%2F...).
#
# STEP 2: Sign in with your Microsoft account.
#
# STEP 3: After sign-in your browser redirects to:
#   {{redirectUri}}?code=<AUTH_CODE>&...
#   The page may show "unable to connect". That is expected.
#   Copy the "code" query parameter value from the URL bar.
#
# STEP 4: Paste the code as @authorizationCode below and run REQUEST 2.
#   Important: if you change @codeVerifier or @codeChallenge, request a new
#   authorization code. Old codes are bound to the original PKCE pair.

###############################################################################
# REQUEST 2: Token exchange
# Exchange the authorization code + code_verifier for access token
###############################################################################

@authorizationCode = <paste-authorization-code-from-redirect-uri>

POST {{entraAuthority}}/{{tenantId}}/oauth2/v2.0/token
Content-Type: application/x-www-form-urlencoded

grant_type=authorization_code&client_id={{callerClientId}}&code={{authorizationCode}}&redirect_uri={{redirectUri}}&code_verifier={{codeVerifier}}&scope={{apiScope}}

###
# Response (example):
# {
#   "token_type": "Bearer",
#   "scope": "api://your-api-client-id/access_as_user",
#   "expires_in": 3599,
#   "ext_expires_in": 3599,
#   "access_token": "eyJhbGciOiJSUzI1NiIsImtpZCI6Ik5rRkJRMFUzUVRVeFFraEZSRE00UWpSR1JEQkJRVEJEVVRaR09FWkVRZz09In0..."
# }
#
# NEXT STEP:
# 1. Copy the access_token value (the long string after "access_token": ")
# 2. Paste it as @apiAccessToken below
# 3. Run REQUEST 3 to call the API

###############################################################################
# REQUEST 3: Call the API with the access token
# Use the token obtained from REQUEST 2 to authenticate to the API
###############################################################################

@apiAccessToken = <paste-access_token-from-request-2-response>

POST {{apiBaseUrl}}/chat/stream
Authorization: Bearer {{apiAccessToken}}
Content-Type: application/json
# Use NDJSON for easier reading in VS Code .http responses.
# SSE remains available with: Accept: text/event-stream
Accept: application/x-ndjson

{
  "prompt": "Summarize yesterday's sales by region"
}
