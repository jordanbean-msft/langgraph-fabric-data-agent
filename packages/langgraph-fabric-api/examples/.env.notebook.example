# Notebook client environment variables
# Copy to .env.notebook and fill your values before running the notebook.
# This file is safe to commit. .env.notebook is gitignored.

# Base URL of the running API server
CHAT_API_BASE_URL=http://localhost:8000

# App registration client ID for the API (the audience of the token)
API_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Optional explicit delegated scope to request (overrides default api://<API_CLIENT_ID>/.default)
API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user

# App registration client ID for the calling notebook client
CALLER_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Entra tenant ID (use "common" for multi-tenant)
TENANT_ID=common
