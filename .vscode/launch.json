{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Workflow: Console (run-console)",
      "type": "debugpy",
      "request": "launch",
      "module": "langgraph_fabric_console.main",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/packages/langgraph-fabric-console/.env",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": true
    },
    {
      "name": "Workflow: API (run-api)",
      "type": "debugpy",
      "request": "launch",
      "module": "langgraph_fabric_api.main",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/packages/langgraph-fabric-api/.env",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": true
    },
    {
      "name": "Workflow: M365 (run-m365)",
      "type": "debugpy",
      "request": "launch",
      "module": "langgraph_fabric_m365.main",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/packages/langgraph-fabric-m365/.env",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": true
    },
    {
      "name": "Tests: core (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "packages/langgraph-fabric-core/tests",
        "-v"
      ],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": false
    },
    {
      "name": "Tests: api (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "packages/langgraph-fabric-api/tests",
        "-v"
      ],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": false
    },
    {
      "name": "Tests: console (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "packages/langgraph-fabric-console/tests",
        "-v"
      ],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": false
    },
    {
      "name": "Tests: m365 (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "packages/langgraph-fabric-m365/tests",
        "-v"
      ],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": false
    },
    {
      "name": "Tests: all (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-v"
      ],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "Workflow: API + M365",
      "configurations": [
        "Workflow: API (run-api)",
        "Workflow: M365 (run-m365)"
      ]
    },
    {
      "name": "Workflow: API + Console",
      "configurations": [
        "Workflow: API (run-api)",
        "Workflow: Console (run-console)"
      ]
    }
  ]
}
