# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# uv / pip
.venv/
*.egg-info/
dist/
build/
appPackage/build/
appPackage/manifest.json

# Environment files (never commit real secrets)
.env
!.env.example
!packages/**/.env.example
!packages/**/.env.notebook.example
.env.my-tenant
.env.notebook

# Testing and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
*.xml

# Linting caches
.ruff_cache/
.mypy_cache/

# VS Code local settings: only ignore root settings if they contain personal overrides.
# The root .vscode/settings.json is committed with shared project settings.
# Use User Settings (Code > Preferences > Open User Settings JSON) for personal overrides.

# macOS
.DS_Store

# Runtime logs and agent output
*.log
agent_output.log

# Azure Developer CLI
.azure/

# Python version override (already tracked via .python-version)
.python-version.local
