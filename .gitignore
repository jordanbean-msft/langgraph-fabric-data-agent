# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# uv / pip
.venv/
uv.lock
*.egg-info/
dist/
build/
appPackage/build/
appPackage/manifest.json

# Environment files (never commit real secrets)
.env
!.env.example
!packages/**/.env.example
.env.my-tenant

# Testing and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
*.xml

# Linting caches
.ruff_cache/
.mypy_cache/

# VS Code local settings
.vscode/settings.json

# macOS
.DS_Store

# Runtime logs and agent output
*.log
agent_output.log

# Azure Developer CLI
.azure/

# Python version override (already tracked via .python-version)
.python-version.local
