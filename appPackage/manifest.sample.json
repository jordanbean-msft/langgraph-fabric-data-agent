{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
  "manifestVersion": "1.25",
  "version": "1.0.0",
  "id": "00000000-0000-0000-0000-000000000000",
  "developer": {
    "name": "Your Organization",
    "websiteUrl": "https://example.azurewebsites.net",
    "privacyUrl": "https://example.azurewebsites.net/privacy",
    "termsOfUseUrl": "https://example.azurewebsites.net/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "Fabric Data Agent",
    "full": "LangGraph Fabric Data Agent"
  },
  "description": {
    "short": "Chat with a Fabric Data Agent through the hosted M365 Agents SDK adapter.",
    "full": "LangGraph Fabric Data Agent is a hosted bot-based Microsoft 365 agent that routes chat prompts through the M365 Agents SDK adapter to a Fabric Data Agent over MCP. Replace the placeholder app ID, domains, and URLs with your deployed values before uploading this package to the Microsoft 365 admin center."
  },
  "accentColor": "#0F766E",
  "copilotAgents": {
    "customEngineAgents": [
      {
        "id": "00000000-0000-0000-0000-000000000000",
        "type": "bot"
      }
    ]
  },
  "bots": [
    {
      "botId": "00000000-0000-0000-0000-000000000000",
      "scopes": ["personal"],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["example.azurewebsites.net"]
}
